# =============================================================================
# ServiceNow MCP server — example environment configuration
#
# Copy this file to .env and fill in values. Never commit a real .env to a
# public repo.
# =============================================================================

# --- ServiceNow connection (south-bound: this server → ServiceNow) ---
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_AUTH_TYPE=basic                       # basic | oauth | api_key

# Basic auth (simplest; fine for local dev against a PDI)
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# OAuth (recommended for production). client_credentials is the primary
# path; username + password are only used for the deprecated password-grant
# fallback (Issue #43 finding #2).
# SERVICENOW_CLIENT_ID=
# SERVICENOW_CLIENT_SECRET=
# SERVICENOW_TOKEN_URL=                          # auto-derived from instance URL if unset
# SERVICENOW_RESOURCE_URL=                       # set for Azure AD-backed flows that require a `resource` parameter

# API Key (header-based)
# SERVICENOW_API_KEY=
# SERVICENOW_API_KEY_HEADER=X-ServiceNow-API-Key

# Optional — applies to all auth types
# SERVICENOW_API_PATH=api                        # default; override for instances with a non-standard API mount
# SERVICENOW_EXTRA_HTTP_HEADERS={"X-Tenant-Id": "acme"}  # JSON dict; merged into every south-bound request

# --- SSE transport security (north-bound: MCP client → this server) ---
# Bearer token required by every /sse and /messages/ request.
# If unset and the server is bound to a loopback address, a token is
# auto-generated at startup and printed once to stderr. Required (no
# auto-gen) when --allow-remote / MCP_ALLOW_REMOTE is set.
# MCP_AUTH_TOKEN=

# Permit binding to non-loopback addresses (e.g. 0.0.0.0 inside Docker).
# Required for cloud / VPS deployments. When set, MCP_AUTH_TOKEN must also
# be set explicitly — auto-generation is refused for safety.
# MCP_ALLOW_REMOTE=

# Comma-separated extra Host header values to accept (e.g. mcp.internal,mcp.internal:8080).
# Loopback (127.0.0.1, localhost, [::1]) is always allowed. DNS-rebinding
# defense — keep this list minimal.
# MCP_ALLOWED_HOSTS=

# --- Tool packaging ---
# Which tool subset to expose. Options: none, service_desk, catalog_builder,
# change_coordinator, knowledge_author, platform_developer, agile_management,
# system_administrator, nl_power_user, full (default).
# MCP_TOOL_PACKAGE=full

# Override the path to the tool-packages YAML (advanced).
# MCP_TOOL_PACKAGE_CONFIG_PATH=
