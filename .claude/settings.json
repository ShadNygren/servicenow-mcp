{
  "$schema": "https://code.claude.com/schemas/settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact-rehydrate.sh",
            "timeout": 10,
            "statusMessage": "Rehydrating CLAUDE.md + memory + planning docs..."
          }
        ]
      }
    ]
  }
}
